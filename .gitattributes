# Normalize line endings to LF across the repo (cross-platform standard).
* text=auto
*.cs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.html text eol=lf
*.css text eol=lf
*.xml text eol=lf
*.csproj text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.dll binary
*.pdb binary
