# Copy to .env and adjust. Used by docker-compose.yml.

# Public entry point (nginx). The web client is built against this origin.
PUBLIC_ORIGIN=http://localhost:8080
PUBLIC_PORT=8080

# API environment: Development enables Swagger at /swagger. Use Production for real deploys.
ASPNETCORE_ENVIRONMENT=Development

# Postgres
POSTGRES_PORT=5432
POSTGRES_USER=watchparty
POSTGRES_PASSWORD=watchparty
POSTGRES_DB=watchparty

# Redis
REDIS_PORT=6379

# JWT signing key — MUST be at least 32 bytes. Change this for any real deployment.
JWT_KEY=CHANGE_ME_USE_A_32_BYTE_MINIMUM_SECRET

# Seed administrator account (created on first startup).
SEED_ADMIN_EMAIL=admin@watchparty.local
SEED_ADMIN_PASSWORD=ChangeMe123!
