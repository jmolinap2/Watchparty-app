@inherits LayoutComponentBase
@inject IHostEnvironment Environment
@inject IStringLocalizer<SharedResource> L

<div class="page @(sidebarExpanded ? "sidebar-expanded" : "sidebar-collapsed")">
    <aside class="sidebar" aria-label="@L["Nav.Navigation"]">
        <NavMenu @bind-IsExpanded="sidebarExpanded" />
    </aside>

    <main>
        <div class="app-topbar">
            <div>
                <span class="topbar-kicker">WatchParty</span>
                <strong>@L["Admin.PanelTitle"]</strong>
            </div>
            <div class="topbar-actions">
                <LanguageSwitcher />
                <span class="environment-pill">@Environment.EnvironmentName</span>
                <UserMenu />
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["Layout.UnhandledError"]
    <a href="." class="reload">@L["Common.Reload"]</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool sidebarExpanded = true;
}
