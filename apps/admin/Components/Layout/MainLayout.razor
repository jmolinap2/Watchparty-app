@inherits LayoutComponentBase
@inject IHostEnvironment Environment
@inject IStringLocalizer<SharedResource> L

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="app-topbar">
            <div>
                <span class="topbar-kicker">WatchParty</span>
                <strong>@L["Admin.PanelTitle"]</strong>
            </div>
            <div class="topbar-actions">
                <LanguageSwitcher />
                <span class="environment-pill">@Environment.EnvironmentName</span>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["Layout.UnhandledError"]
    <a href="." class="reload">@L["Common.Reload"]</a>
    <span class="dismiss">x</span>
</div>
