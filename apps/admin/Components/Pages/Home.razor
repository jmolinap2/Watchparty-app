@page "/"
@inherits AdminPageBase
@inject IConfiguration Configuration

<PageTitle>@Text("Admin.AppTitle")</PageTitle>

<section class="admin-shell">
    <header class="admin-header">
        <div>
            <h1>@Text("Nav.Dashboard")</h1>
            <p>@Text("Home.Subtitle")</p>
        </div>
        <div class="header-actions">
            <button @onclick="LoadInitialAsync" disabled="@Loading">@Text("Common.Refresh")</button>
        </div>
    </header>

    <section class="diagnostic-strip">
        <div>
            <span>@Text("Diagnostic.Api")</span>
            <code>@BackendApiUrl</code>
        </div>
        <div>
            <span>@Text("Diagnostic.AdminLog")</span>
            <code>@AdminLogPath</code>
        </div>
        <div>
            <span>@Text("Diagnostic.ApiLog")</span>
            <code>@ApiLogPath</code>
        </div>
    </section>

    @if (Message is not null)
    {
        <div class="notice @(MessageIsError ? "notice-error" : null)">@Message</div>
    }

    @if (data is null)
    {
        <div class="loading-panel">
            <span class="loading-spinner" aria-hidden="true"></span>
            <span>@Text("Common.Loading")</span>
        </div>
    }
    else
    {
        <section class="metric-grid">
            <MetricCard Label="@Text("Metrics.Users")" Value="@data.Metrics.RegisteredUsers" />
            <MetricCard Label="@Text("Metrics.ActiveUsers")" Value="@data.Metrics.ActiveUsers" />
            <MetricCard Label="@Text("Metrics.Rooms")" Value="@data.Metrics.RoomsCreated" />
            <MetricCard Label="@Text("Metrics.ActiveRooms")" Value="@data.Metrics.ActiveRooms" />
            <MetricCard Label="@Text("Metrics.Messages")" Value="@data.Metrics.MessagesSent" />
            <MetricCard Label="@Text("Metrics.OpenReports")" Value="@data.Metrics.OpenReports" />
            <MetricCard Label="@Text("Metrics.PlaybackErrors")" Value="@data.Metrics.PlaybackErrors" />
            <MetricCard Label="@Text("Metrics.Reconnections")" Value="@data.Metrics.SignalrReconnections" />
        </section>

        <div class="dashboard-columns">
            <DataTable TItem="AdminUserDto" Title="@Text("Sections.Users")" ColumnCount="2"
                       Items="data.RecentUsers.Items" EmptyText="@Text("Common.Empty")">
                <Toolbar><a class="link-pill" href="users">@Text("Common.ViewAll")</a></Toolbar>
                <HeaderTemplate>
                    <th>@Text("Table.Name")</th>
                    <th>@Text("Table.Role")</th>
                </HeaderTemplate>
                <RowTemplate Context="user">
                    <td class="strong-cell">@user.DisplayName<small class="muted-line">@user.Email</small></td>
                    <td><span class="badge neutral">@TranslateValue("Enum.Role", user.Role)</span></td>
                </RowTemplate>
            </DataTable>

            <DataTable TItem="AdminRoomDto" Title="@Text("Sections.Rooms")" ColumnCount="2"
                       Items="data.ActiveRooms.Items" EmptyText="@Text("Common.Empty")">
                <Toolbar><a class="link-pill" href="rooms">@Text("Common.ViewAll")</a></Toolbar>
                <HeaderTemplate>
                    <th>@Text("Table.Name")</th>
                    <th>@Text("Table.Online")</th>
                </HeaderTemplate>
                <RowTemplate Context="room">
                    <td class="strong-cell">@room.Name<small class="muted-line">@room.Code</small></td>
                    <td>@room.OnlineCount / @room.MemberCount</td>
                </RowTemplate>
            </DataTable>

            <DataTable TItem="ReportDto" Title="@Text("Metrics.OpenReports")" ColumnCount="2"
                       Items="data.OpenReports.Items" EmptyText="@Text("Common.Empty")">
                <Toolbar><a class="link-pill" href="reports">@Text("Common.ViewAll")</a></Toolbar>
                <HeaderTemplate>
                    <th>@Text("Table.Type")</th>
                    <th>@Text("Table.Reason")</th>
                </HeaderTemplate>
                <RowTemplate Context="report">
                    <td><span class="badge warning">@TranslateValue("Enum.ReportType", report.Type)</span></td>
                    <td>@report.Reason</td>
                </RowTemplate>
            </DataTable>
        </div>
    }
</section>

@code {
    private DashboardData? data;

    private string BackendApiUrl => Configuration["BackendApi:BaseUrl"] ?? "https://localhost:7001";
    private string AdminLogPath => WatchPartyLogPaths.ResolveLogFilePath(Configuration, "watchparty-admin.log");
    private string ApiLogPath => WatchPartyLogPaths.ResolveLogFilePath(Configuration, "watchparty-api.log", useConfiguredFileName: false);

    protected override Task LoadInitialAsync() =>
        RunAsync(async () => data = await Api.GetDashboardAsync());
}
