@page "/login"
@layout EmptyLayout
@inject AdminApiClient Api
@inject AdminSession Session
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject IHostEnvironment Environment
@inject IStringLocalizer<SharedResource> L
@inject ILogger<Login> Logger

<PageTitle>@L["Login.PageTitle"]</PageTitle>

<div class="login-shell">
    <div class="login-panel">
        <section class="login-context">
            <p class="eyebrow">WatchParty Admin</p>
            <h1>@L["Auth.SignIn"]</h1>
            <dl class="diagnostic-grid">
                <div>
                    <dt>@L["Diagnostic.Api"]</dt>
                    <dd><code>@BackendApiUrl</code></dd>
                </div>
                <div>
                    <dt>@L["Diagnostic.Environment"]</dt>
                    <dd>@Environment.EnvironmentName</dd>
                </div>
                <div>
                    <dt>@L["Diagnostic.AdminLog"]</dt>
                    <dd><code>@AdminLogPath</code></dd>
                </div>
                <div>
                    <dt>@L["Diagnostic.ApiLog"]</dt>
                    <dd><code>@ApiLogPath</code></dd>
                </div>
                <div>
                    <dt>@L["Diagnostic.MigratorLog"]</dt>
                    <dd><code>@MigratorLogPath</code></dd>
                </div>
            </dl>
        </section>

        <section class="login-form-panel">
            <EditForm Model="model" OnValidSubmit="LoginAsync" FormName="login">
                <div class="field">
                    <label>@L["Auth.Identifier"]</label>
                    <InputText @bind-Value="model.Identifier" placeholder="admin" autocomplete="username" />
                    @if (!string.IsNullOrWhiteSpace(identifierError))
                    {
                        <div class="validation-message">@identifierError</div>
                    }
                </div>
                <div class="field">
                    <label>@L["Auth.Password"]</label>
                    <InputText type="password" @bind-Value="model.Password" placeholder="********" autocomplete="current-password" />
                    @if (!string.IsNullOrWhiteSpace(passwordError))
                    {
                        <div class="validation-message">@passwordError</div>
                    }
                </div>
                <button type="submit" class="primary" disabled="@loading">
                    @(loading ? L["Auth.SigningIn"] : L["Auth.SignIn"])
                </button>
            </EditForm>

            @if (failure is not null)
            {
                <div class="login-error" role="alert">
                    <strong>@failure.Title</strong>
                    <p>@failure.Message</p>
                    <dl class="failure-details">
                        <div>
                            <dt>@L["Login.Attempt"]</dt>
                            <dd>@failure.OccurredAt</dd>
                        </div>
                        <div>
                            <dt>@L["Common.Status"]</dt>
                            <dd>@failure.Status</dd>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(failure.Code))
                        {
                            <div>
                                <dt>@L["Common.Code"]</dt>
                                <dd><code>@failure.Code</code></dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(failure.CorrelationId))
                        {
                            <div>
                                <dt>@L["Common.Correlation"]</dt>
                                <dd><code>@failure.CorrelationId</code></dd>
                            </div>
                        }
                    </dl>
                </div>
            }
        </section>
    </div>
</div>

@code {
    private readonly LoginModel model = new();
    private LoginFailure? failure;
    private string? identifierError;
    private string? passwordError;
    private bool loading;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string BackendApiUrl => Configuration["BackendApi:BaseUrl"] ?? "https://localhost:7001";
    private string AdminLogPath => WatchPartyLogPaths.ResolveLogFilePath(Configuration, "watchparty-admin.log");
    private string ApiLogPath => WatchPartyLogPaths.ResolveLogFilePath(Configuration, "watchparty-api.log", useConfiguredFileName: false);
    private string MigratorLogPath => WatchPartyLogPaths.ResolveLogFilePath(Configuration, "watchparty-migrator.log", useConfiguredFileName: false);

    private string Target => ReturnUrl is not null && ReturnUrl.StartsWith('/') ? ReturnUrl : "/";

    protected override void OnAfterRender(bool firstRender)
    {
        // Session is restored by AdminSessionBoundary before the router runs, so an
        // already-signed-in admin landing on /login is bounced straight to the panel.
        if (firstRender && Session.IsAdmin)
        {
            Nav.NavigateTo(Target, replace: true);
        }
    }

    private async Task LoginAsync()
    {
        loading = true;
        failure = null;
        identifierError = string.IsNullOrWhiteSpace(model.Identifier) ? L["Validation.IdentifierRequired"].Value : null;
        passwordError = string.IsNullOrWhiteSpace(model.Password) ? L["Validation.PasswordRequired"].Value : null;

        if (identifierError is not null || passwordError is not null)
        {
            loading = false;
            return;
        }

        try
        {
            var result = await Api.LoginAsync(model.Identifier, model.Password);

            if (!string.Equals(result.User.Role, AdminSession.AdminRole, StringComparison.OrdinalIgnoreCase))
            {
                // Valid credentials but not an administrator: never persist the session.
                failure = new LoginFailure(
                    L["Login.NotAdminTitle"],
                    L["Login.NotAdminMessage"],
                    "403",
                    "identity.not_admin",
                    null,
                    DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
                Logger.LogWarning("Non-admin login rejected for {Identifier}. Role={Role}.", model.Identifier, result.User.Role);
                return;
            }

            await Session.SetTokenAsync(result);
            Nav.NavigateTo(Target, replace: true);
        }
        catch (AdminApiException ex)
        {
            failure = BuildFailure(ex);
            Logger.LogWarning(
                ex,
                "Admin login failed. Status={Status}; Code={Code}; CorrelationId={CorrelationId}; BackendApi={BackendApi}",
                ex.StatusText,
                ex.ApiCode ?? "-",
                ex.CorrelationId ?? "-",
                BackendApiUrl);
        }
        catch (Exception ex)
        {
            failure = new LoginFailure(
                L["Login.UnexpectedTitle"],
                ex.Message,
                L["Login.LocalError"],
                null,
                null,
                DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
            Logger.LogError(ex, "Unexpected admin login failure.");
        }
        finally
        {
            loading = false;
        }
    }

    private LoginFailure BuildFailure(AdminApiException ex)
    {
        var occurredAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
        var code = ex.ApiCode;

        if (ex.StatusCode is HttpStatusCode.Unauthorized || code == "identity.invalid_credentials")
        {
            return new LoginFailure(
                L["Login.InvalidCredentialsTitle"],
                L["Login.InvalidCredentialsMessage"],
                ex.StatusText,
                code,
                ex.CorrelationId,
                occurredAt);
        }

        if (ex.StatusCode is HttpStatusCode.Forbidden && code == "identity.account_blocked")
        {
            return new LoginFailure(
                L["Login.AccountBlockedTitle"],
                L["Login.AccountBlockedMessage"],
                ex.StatusText,
                code,
                ex.CorrelationId,
                occurredAt);
        }

        if (!ex.HasHttpResponse)
        {
            return new LoginFailure(
                L["Login.NoApiTitle"],
                L["Login.NoApiMessage"],
                ex.StatusText,
                code,
                ex.CorrelationId,
                occurredAt);
        }

        if ((int)ex.StatusCode!.Value >= 500)
        {
            return new LoginFailure(
                L["Login.ApiInternalTitle"],
                L["Login.ApiInternalMessage"],
                ex.StatusText,
                code,
                ex.CorrelationId,
                occurredAt);
        }

        return new LoginFailure(
            L["Login.ApiRejectedTitle"],
            ex.ApiMessage ?? ex.Message,
            ex.StatusText,
            code,
            ex.CorrelationId,
            occurredAt);
    }

    private sealed class LoginModel
    {
        public string Identifier { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private sealed record LoginFailure(
        string Title,
        string Message,
        string Status,
        string? Code,
        string? CorrelationId,
        string OccurredAt);
}
