@if (TotalPages > 1)
{
    <nav class="pager" aria-label="pagination">
        @if (!string.IsNullOrEmpty(Info))
        {
            <span class="pager-info">@Info</span>
        }
        <div class="pager-buttons">
            <button type="button" class="ghost" disabled="@(Page <= 1)" @onclick="() => Go(Page - 1)" aria-label="previous">‹</button>
            <span class="pager-current">@Page / @TotalPages</span>
            <button type="button" class="ghost" disabled="@(Page >= TotalPages)" @onclick="() => Go(Page + 1)" aria-label="next">›</button>
        </div>
    </nav>
}

@code {
    [Parameter] public int Page { get; set; }
    [Parameter] public int PageSize { get; set; }
    [Parameter] public long TotalCount { get; set; }
    [Parameter] public string? Info { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private int TotalPages => PageSize <= 0 ? 1 : Math.Max(1, (int)Math.Ceiling(TotalCount / (double)PageSize));

    private Task Go(int page)
    {
        if (page < 1 || page > TotalPages || page == Page)
        {
            return Task.CompletedTask;
        }

        return OnPageChanged.InvokeAsync(page);
    }
}
